# Sao chép file này thành .env rồi điền giá trị thật:
#   cp .env.example .env
#
# LUỜu Ý: KHÔNG bao giờ commit file .env lên GitHub!

# Gemini AI — lấy key miễn phí tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Bảo vệ API ghi dữ liệu (POST/PUT) — đặt mật khẩu bất kỳ
API_SECRET=your_secret_password_here

# Chỉ cho phép domain này gọi API — thay bằng domain thật khi deploy
ALLOWED_ORIGIN=http://localhost:3000

# Cổng chạy server (mặc định 3000)
PORT=3000
